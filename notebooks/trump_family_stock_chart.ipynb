   "source": [
    "# Calculate additional statistics\n",
    "print(\"=\" * 80)\n",
    "print(\"YEAR-TO-DATE PERFORMANCE RANKING\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "performance = df_pct_change.iloc[-1].sort_values(ascending=False)\n",
    "for i, (ticker, pct) in enumerate(performance.items(), 1):\n",
    "    status = \"📈\" if pct > 0 else \"📉\"\n",
    "    print(f\"{i:2d}. {ticker:35s} {status} {pct:+8.2f}%\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"VOLATILITY ANALYSIS (1-Year Rolling Std Dev)\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "volatility = df_combined.pct_change().std() * np.sqrt(252) * 100\n",
    "volatility_sorted = volatility.sort_values(ascending=False)\n",
    "for ticker, vol in volatility_sorted.items():\n",
    "    print(f\"{ticker:35s}: {vol:6.2f}% annualized volatility\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"CURRENT PRICES (Latest Available)\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "current_prices = df_combined.iloc[-1].sort_values(ascending=False)\n",
    "for ticker, price in current_prices.items():\n",
    "    print(f\"{ticker:35s}: ${price:12.4f}\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)"
   ]
  },
