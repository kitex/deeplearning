   "source": [
    "# Create subplots for different price ranges\n",
    "# Split by category for better visibility\n",
    "fig, axes = plt.subplots(3, 1, figsize=(14, 12))\n",
    "\n",
    "# Plot 1: High-priced tech stocks (separated due to scale)\n",
    "high_price_cols = ['Nvidia', 'Apple', 'Microsoft', 'Dell Technologies', 'Meta Platforms']\n",
    "high_price_data = df_combined[[col for col in high_price_cols if col in df_combined.columns]]\n",
    "if len(high_price_data.columns) > 0:\n",
    "    for col in high_price_data.columns:\n",
    "        axes[0].plot(high_price_data.index, high_price_data[col], label=col, linewidth=2.5, marker='', alpha=0.8)\n",
    "    axes[0].set_title('High-Priced Tech Stocks', fontsize=12, fontweight='bold')\n",
    "    axes[0].set_ylabel('Price ($)', fontsize=11)\n",
    "    axes[0].legend(fontsize=9, loc='best')\n",
    "    axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 2: Mid-priced stocks\n",
    "mid_price_cols = ['Palantir', 'TKO Group Holdings', 'Powerus (Aureus Greenway)']\n",
    "mid_price_data = df_combined[[col for col in mid_price_cols if col in df_combined.columns]]\n",
    "if len(mid_price_data.columns) > 0:\n",
    "    for col in mid_price_data.columns:\n",
    "        axes[1].plot(mid_price_data.index, mid_price_data[col], label=col, linewidth=2.5, marker='', alpha=0.8)\n",
    "    axes[1].set_title('Mid-Priced Securities', fontsize=12, fontweight='bold')\n",
    "    axes[1].set_ylabel('Price ($)', fontsize=11)\n",
    "    axes[1].legend(fontsize=9, loc='best')\n",
    "    axes[1].grid(True, alpha=0.3)\n",
     "plt.tight_layout()\n",
     "plt.show()\n"
    ]
   }
  ]
