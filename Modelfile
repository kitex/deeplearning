FROM gemma4:12b
PARAMETER num_ctx 8192
SYSTEM "You are an expert coding assistant. Provide only the final code and concise explanations."

# Trick Gemma 4 into thinking it has already finished its reasoning block
TEMPLATE """{{ if .System }}<start_of_turn>model
{{ .System }}<end_of_turn>
{{ end }}{{ if .Prompt }}<start_of_turn>user
{{ .Prompt }}<end_of_turn>
{{ end }}<start_of_turn>model
<|channel>thought
<channel|>
"""